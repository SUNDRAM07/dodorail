# ========================================
# DodoRail — environment variables template
# Copy to .env for local dev. Never commit .env.
# ========================================

# --- Database (Neon Postgres) ---
# Pooled connection for the app (has -pooler in the host)
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/dodorail?sslmode=require"
# Direct (non-pooled) connection for Prisma migrate — optional, Neon-specific
DIRECT_URL="postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/dodorail?sslmode=require"

# --- Public app URL ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_BUILD_VERSION="0.1.0"
NEXT_PUBLIC_GIT_SHA=""

# --- Dodo Payments ---
# Day 1: mock mode. Flip to 'live' once the API key is tested.
DODORAIL_DODO_MODE="mock"
DODORAIL_DODO_KEY=""
DODORAIL_DODO_WEBHOOK_SECRET=""

# --- Solana / Helius ---
DODORAIL_HELIUS_KEY=""
DODORAIL_QUICKNODE_URL=""

# --- Analytics integrations (Day 7-10) ---
DODORAIL_DUNE_KEY=""
DODORAIL_GOLDRUSH_KEY=""

# --- Privacy integrations (Day 10-12) ---
DODORAIL_UMBRA_KEY=""
DODORAIL_MAGICBLOCK_KEY=""

# --- Yield (Day 11-12) ---
DODORAIL_LPAGENT_KEY=""

# --- Agent (separate repo; keep here for shared schema) ---
DODORAIL_ZERION_KEY=""
DODORAIL_ANTHROPIC_KEY=""
DODORAIL_TELEGRAM_BOT_TOKEN=""

# --- Observability (set up Day 3) ---
SENTRY_DSN=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
AXIOM_TOKEN=""

# --- Email (Day 5+) ---
RESEND_API_KEY=""
