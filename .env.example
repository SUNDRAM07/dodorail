# DodoRail · environment variables
#
# Copy to .env at the repo root and fill in. Most integrations have a "mock"
# mode that runs without keys — start with DATABASE_URL only and add keys as
# you need each feature.
#
# Production env lives on Vercel (https://vercel.com/sundrams-projects-1c401878/dodorail)
# and on GitHub Actions secrets (for the Treasury Agent cron).

# ============================================================================
# Required — DB
# ============================================================================

# Neon Postgres (or any Postgres). Use the pooled URL from Neon's dashboard.
DATABASE_URL="postgres://username:password@host/dbname?sslmode=require"

# Direct (non-pooled) URL for Prisma migrations only.
DIRECT_URL="postgres://username:password@host/dbname?sslmode=require"

# ============================================================================
# Required — auth
# ============================================================================

# 32+ random bytes, base64-encoded. Used to HMAC-sign session cookies.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
DODORAIL_SESSION_SECRET=""

# ============================================================================
# Solana (mainnet OR devnet)
# ============================================================================

# Helius RPC endpoint (recommended). Falls back to public RPC if unset.
NEXT_PUBLIC_SOLANA_RPC_URL="https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY"

# Helius webhook secret — used to verify the inbound Helius webhook auth header.
DODORAIL_HELIUS_WEBHOOK_SECRET=""

# Helius API key for general Solana RPC + Enhanced Transactions usage.
DODORAIL_HELIUS_KEY=""

# ============================================================================
# Dodo Payments (cards + UPI rail)
# ============================================================================

# "live" | "mock". "mock" returns deterministic data without hitting Dodo.
DODORAIL_DODO_MODE="mock"

# Dodo REST API key. Get from https://dashboard.dodopayments.com.
DODORAIL_DODO_KEY=""

# Webhook signing secret. Get from your Dodo dashboard's webhook settings.
DODORAIL_DODO_WEBHOOK_SECRET=""

# ============================================================================
# Sponsor integrations (each has mock mode if key is unset)
# ============================================================================

# Dune Analytics — for the public + private analytics layer.
DODORAIL_DUNE_KEY=""
DODORAIL_DUNE_QUERY_ID_USDC_VOLUME_7D=""

# GoldRush (Covalent) — multi-chain wallet data API.
DODORAIL_GOLDRUSH_KEY=""

# Umbra — privacy provider (mainnet + devnet support).
DODORAIL_UMBRA_KEY=""

# MagicBlock Private Payments — institutional TDX privacy. Currently architectural-only.
DODORAIL_MAGICBLOCK_KEY=""

# LP Agent (Nimbus Data Labs) — Meteora DLMM yield API.
DODORAIL_LPAGENT_KEY=""

# Zerion — wallet portfolio API for the Treasury Agent.
DODORAIL_ZERION_KEY=""

# LayerZero OFT Transfer API — for cross-chain USDT0 quotes (Tether track).
DODORAIL_LAYERZERO_KEY=""

# Anthropic Claude API — premium reasoner backend for the Treasury Agent (optional).
DODORAIL_ANTHROPIC_KEY=""

# Google AI Studio — free Gemini 2.5 Flash reasoner backend for the agent.
# Free tier: 1500 req/day. Get from https://aistudio.google.com/app/apikey
DODORAIL_GEMINI_KEY=""

# Telegram bot — for agent alerts. Create via @BotFather.
DODORAIL_TELEGRAM_BOT_TOKEN=""

# ============================================================================
# Treasury Agent — runtime config (apps/agent only)
# ============================================================================

# "zerion" | "goldrush" — picks the agent's data adapter. Defaults to "zerion".
DODORAIL_AGENT_DATA_SOURCE="zerion"

# "mock" | "gemini" | "anthropic" — picks the LLM reasoner backend.
# Mock works without any LLM key. Defaults to mock.
DODORAIL_AGENT_REASONER="mock"

# "true" to actually submit zap-in transactions on chain. Defaults to false (dry-run).
# Only flip true after Squads multisig is wired (Day 18+ work).
DODORAIL_AGENT_LIVE_TX="false"

# Cron schedule for the daemon mode (vs the GitHub Actions cron). Default: every 5 min.
DODORAIL_AGENT_CRON="*/5 * * * *"

# Squads multisig PDA — when set, agent uses delegated signer flow. Day 18+.
DODORAIL_SQUADS_MULTISIG_PDA=""

# Agent's operating wallet address — must be one of the multisig signers.
DODORAIL_AGENT_WALLET_ADDRESS=""

# "mock" | "live" — Squads adapter mode. Defaults to mock.
DODORAIL_SQUADS_MODE="mock"

# ============================================================================
# Vercel cron auth
# ============================================================================

# Bearer secret for /api/cron/treasury-sweep. Vercel sets this automatically when
# CRON_SECRET is in the project's env vars (Vercel adds the Bearer auth header).
CRON_SECRET=""

# ============================================================================
# Observability (optional)
# ============================================================================

# Sentry — error tracking.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# Posthog — product analytics. EU instance.
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"

# ============================================================================
# Build / deployment metadata
# ============================================================================

NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_BUILD_VERSION="0.1.0"
