{
  "name": "dodorail",
  "version": "0.1.0",
  "private": true,
  "description": "The stablecoin rail for Indian founders selling globally.",
  "homepage": "https://github.com/SUNDRAM07/dodorail",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SUNDRAM07/dodorail.git"
  },
  "license": "MIT",
  "author": "Sundaram Mahajan",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "db:generate": "turbo run db:generate",
    "db:migrate": "pnpm --filter @dodorail/db db:migrate",
    "db:seed": "pnpm --filter @dodorail/db db:seed",
    "db:studio": "pnpm --filter @dodorail/db db:studio",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,mdx,yml,yaml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,mdx,yml,yaml}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.3.0",
    "typescript": "^6.0.3"
  }
}
